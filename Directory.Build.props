<Project>

  <!-- Global Properties -->
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
      <NoWarn>RS1038</NoWarn>
  </PropertyGroup>

  <!-- Package Metadata -->
  <PropertyGroup>
    <Authors>Daniel Karlsson</Authors>
    <Copyright>Copyright (c) 2026 Daniel Karlsson</Copyright>
    <PackageProjectUrl>https://github.com/karlssberg/Converj</PackageProjectUrl>
    <RepositoryUrl>https://github.com/karlssberg/Converj</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageIcon>icon.png</PackageIcon>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReleaseNotes>2.0 renames the public attribute surface: [FluentFactory] -> [FluentRoot], [FluentConstructor] -> [FluentTarget], CreateMethod -> TerminalMethod, CreateVerb -> TerminalVerb. Adds static method targets and extension method targets. See the "Migrating from 1.x" section in the README.</PackageReleaseNotes>
  </PropertyGroup>

  <!-- Reproducible builds and source debugging -->
  <PropertyGroup>
    <Deterministic>true</Deterministic>
    <!-- Stamp deterministic source paths only on CI to keep local builds debuggable -->
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <!-- Embed symbols in the assemblies; the package hand-copies DLLs, so a separate
         symbol package would not capture the generator/attributes PDBs -->
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" PrivateAssets="all" />
  </ItemGroup>

  <!-- Version Management -->
  <!-- This is only a default for local builds. On CI the Publish workflow passes
       -p:Version=<tag> (e.g. 2.1.0 from tag v2.1.0), which cascades to AssemblyVersion,
       FileVersion, and PackageVersion. The git tag is the single source of truth for
       released versions, so leave AssemblyVersion/FileVersion/PackageVersion unset here. -->
  <PropertyGroup>
    <Version>0.0.0-dev</Version>
  </PropertyGroup>
</Project>